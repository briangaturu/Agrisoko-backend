# Crop endpoints

# Get all crops
GET http://localhost:5000/api/crops

# Get crop by id
###
GET http://localhost:5000/api/crops/1

# Create crop
###
POST http://localhost:5000/api/crops
Content-Type: application/json

{
  "name": "Maize",
  "category": "Grains",
  "unit": "kg",
  "cropUrl": "https://example.com/maize.jpg"
}

# Update crop
###
PUT http://localhost:5000/api/crops/1
Content-Type: application/json

{
  "name": "Updated Maize",
  "category": "Cereals"
}

# Delete crop
###
DELETE http://localhost:5000/api/crops/1

